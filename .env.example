# Copy this file to `.env` at the repo root and fill in the values you need.
# `eval/runner.py` loads `.env` automatically at startup via python-dotenv.
# Only the keys for harnesses you actually run need to be set.

# ---- Anthropic harnesses (thin, langgraph, langgraph_react, claude_sdk) ----
# Required for any of the four Anthropic-backed harnesses, AND for the
# research-task LLM-as-judge regardless of which harness produced the answer
# (the judge is pinned to Anthropic to keep cross-provider scoring consistent).
ANTHROPIC_API_KEY=sk-ant-...

# ---- OpenAI harnesses (openai_thin, openai_langgraph, openai_langgraph_react, openai_agents) ----
# Required for any of the four OpenAI-backed harnesses.
OPENAI_API_KEY=sk-...

# Optional. Point at any OpenAI-compatible server to run the same harnesses
# against open-source models (vLLM, Ollama, OpenRouter, Together, LM Studio,
# llama.cpp, ...). Omit to use api.openai.com.
# OPENAI_BASE_URL=http://localhost:8000/v1     # vLLM
# OPENAI_BASE_URL=http://localhost:11434/v1    # Ollama
# OPENAI_BASE_URL=https://openrouter.ai/api/v1 # OpenRouter

# Optional. Default OpenAI model to use when --openai-model isn't passed.
# The CLI flag wins if both are set.
# OPENAI_MODEL=gpt-5

# ---- Gemini (`thin --provider gemini`) ----
# Required for `thin --provider gemini`. The google-genai SDK reads this env
# var automatically. Both GOOGLE_API_KEY and GEMINI_API_KEY are accepted;
# GOOGLE_API_KEY takes precedence if both are set.
# GOOGLE_API_KEY=AIza...
#
# Optional. Default Gemini model when GEMINI_MODEL isn't set.
# GEMINI_MODEL=gemini-2.5-pro

# ---- LangSmith observability (optional, all harnesses) ----
# Set LANGSMITH_TRACING=true to enable end-to-end tracing of every model call,
# tool call, and graph step. When unset (or set to anything falsy), all
# tracing helpers in eval/tracing.py are no-ops with zero overhead.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=harness-benchmark
